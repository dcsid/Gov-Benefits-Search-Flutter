# EditorConfig — consistent style across editors.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.dart]
indent_size = 2

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml,ts,tsx,js,jsx,mjs,cjs,css,scss,html}]
indent_size = 2
